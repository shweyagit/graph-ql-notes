# ── Copy these into Railway environment variables ─────────────────────────────

# PostgreSQL — Railway fills these automatically if you add a Postgres plugin
DB_HOST=
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=

# Auth — generate a strong random string, e.g: openssl rand -hex 32
JWT_SECRET=

# App
PORT=4000
NODE_ENV=production

# Optional — only needed if you want Datadog APM in prod
# DD_API_KEY=
# DD_SITE=datadoghq.eu
# DD_SERVICE=sourcebook
# DD_ENV=production

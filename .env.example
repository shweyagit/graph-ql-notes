JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=PROJ

# Stripe (test mode)
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret_here

# Outgoing webhooks
WEBHOOK_URL=https://webhook.site/your-unique-url
WEBHOOK_SECRET=whsec_my_notes_app_secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=gql_notes
DB_USER=postgres
DB_PASSWORD=postgres

# ── Datadog ────────────────────────────────────────────────────────────────────
# Get your API key from: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your-datadog-api-key

# Datadog intake site — datadoghq.com (US1, default) or datadoghq.eu (EU)
DD_SITE=datadoghq.eu

# Service metadata shown in APM / dashboards
DD_SERVICE=gql-notes
DD_ENV=development

# Agent addresses (defaults work when using docker-compose.datadog.yml)
DD_AGENT_HOST=localhost
DD_TRACE_PORT=8126
